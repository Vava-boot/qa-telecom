# ──────────────────────────────────────────────
#  QA Telecom — Variáveis de Ambiente (Back-end)
#  Copie este arquivo para .env e preencha os valores
#  NUNCA commite o arquivo .env
# ──────────────────────────────────────────────

# Chave da OpenRouter (obtenha em https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-SUA_CHAVE_AQUI

# Porta do servidor (padrão 3001)
PORT=3001

# Origens permitidas pelo CORS (separe por vírgula se houver mais de uma)
# Desenvolvimento:
ALLOWED_ORIGINS=http://localhost:5173
# Produção (exemplo):
# ALLOWED_ORIGINS=https://qa.seudominio.com.br
